/** pagination - Editorial · 琥珀分页 **/

.pagination
  display flex
  flex-direction row
  justify-content center
  list-style none
  white-space nowrap
  width 100%
  padding-top 2em

  a, span
    -webkit-font-smoothing antialiased
    font-size 13px
    color #78716C
    letter-spacing 0.1em
    font-weight 500
    padding 8px 12px
    text-decoration none
    transition all 0.15s ease-out
    border-radius 8px

  .page-number
    margin 0 8px
    box-sizing border-box
    position relative
    display inline

    &.disabled
      display none

    &:hover a
      color #B45309
      background rgba(180, 83, 9, 0.1)

    .dark-theme &:hover a
      color #E8B765
      background rgba(232, 183, 101, 0.1)

    &.current
      a
        color #FFFFFF
        background #B45309

      .dark-theme & a
        color #1A1816
        background #E8B765
