//// ========== TOC - Editorial · 琥珀目录 ========== //

$post-toc-width = 14rem

$padding-4 = 0.25rem
$padding-6 = 0.375rem
$padding-12 = 0.75rem
$padding-14 = 0.875rem
$padding-16 = 1rem

$font-size-12 = 0.75rem
$font-size-13 = 0.8125rem

.post-toc
  position fixed
  top 100px
  right 2em
  width $post-toc-width
  font-size $font-size-13

  .tocbot-list
    max-height 60vh
    max-width 220px
    overflow auto
    position relative
    padding-right $padding-14

    &::-webkit-scrollbar
      width 4px
      height 4px

    &::-webkit-scrollbar-thumb
      background-color #FAEEE1
      border-radius 2px

    .dark-theme &::-webkit-scrollbar-thumb
      background-color #3A352F

    ul
      list-style none
      position inherit
      overflow hidden

      li
        margin-left $padding-4

    a
      color #78716C
      transition color 0.12s ease-out

      &:hover
        color #B45309

    .dark-theme & a
      color #A89E88

      &:hover
        color #E8B765

  .toc-link::before
    background-color transparent

  .is-active-link
    color #B45309 !important
    font-weight 500

    .dark-theme &
      color #E8B765 !important

  .is-active-link::before
    background-color #B45309

    .dark-theme &
      background-color #E8B765

  .tocbot-list-menu
    margin $padding-16 $padding-12
    font-size $font-size-12

    a
      display block
      margin $padding-6 0
      color #78716C
      cursor pointer
      transition color 0.12s ease-out

    a:hover
      color #B45309

    .dark-theme & a
      color #A89E88

    .dark-theme & a:hover
      color #E8B765
